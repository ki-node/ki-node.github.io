{
  "name": "ki-node",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "sync:projects": "node scripts/sync-projects.mjs",
    "check:projects": "node scripts/check-projects.mjs",
    "check:project-copy": "node scripts/check-project-copy.mjs dist/projects",
    "check:ios-project-copy": "node scripts/check-project-copy.mjs ios/App/App/public/projects",
    "check:ios-signing": "node scripts/check-ios-signing.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format:check": "prettier --check . --ignore-unknown",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "check": "npm run check:projects && npm run check:ios-signing && npm run typecheck && npm run lint && npm run format:check && npm run test"
  },
  "dependencies": {
    "@capacitor/app-launcher": "8.0.1",
    "@capacitor/core": "8.4.1",
    "@capacitor/filesystem": "8.1.2",
    "@capacitor/haptics": "8.0.2",
    "@capacitor/ios": "8.4.1",
    "@capacitor/share": "8.0.1",
    "@capacitor/splash-screen": "8.0.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@capacitor/cli": "8.4.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "eslint": "10.7.0",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
